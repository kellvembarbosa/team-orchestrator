#!/usr/bin/env bash
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-}"
if [ -z "$ROOT" ]; then
  ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi
export CLAUDE_PLUGIN_ROOT="$ROOT"

LIB="$ROOT/lib"
. "$LIB/targets.sh"
. "$LIB/emit_claude.sh"
. "$LIB/emit_codex.sh"

RESERVED_RE='^(new|delete|delete-all|list|seed|setup-claude|setup-codex|uninstall)$'
SLUG_RE='^[a-z]([a-z0-9-]{0,38}[a-z0-9])?$'

die() { echo "team: $*" >&2; exit 1; }

cmd_new() {
  local name="" instr="" model="" size="" target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -n|--name)         name="${2:-}";   shift 2 ;;
      -i|--instructions) instr="${2:-}";  shift 2 ;;
      -m|--model)        model="${2:-}";  shift 2 ;;
      -s|--size)         size="${2:-}";   shift 2 ;;
      -t|--target)       target="${2:-}"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  [ -n "$name" ]  || die "missing --name"
  [ -n "$instr" ] || die "missing --instructions"
  [[ "$name" =~ $RESERVED_RE ]] && die "'$name' is a reserved name"
  [[ "$name" =~ $SLUG_RE ]]     || die "invalid slug: kebab-case (a-z, 0-9, -), start with letter"
  [ -n "$size" ] && ! [[ "$size" =~ ^[0-9]+$ ]] && die "--size must be integer"

  local resolved
  resolved="$(targets_resolve "$target")" || exit 1

  # collision check across all targets being written
  for t in $resolved; do
    case "$t" in
      claude) claude_has "$name" && die "team '$name' already exists (claude)" ;;
      codex)  codex_has  "$name" && die "team '$name' already exists (codex)"  ;;
    esac
  done

  for t in $resolved; do
    case "$t" in
      claude) claude_emit "$name" "$instr" "$model" "$size" ;;
      codex)  codex_emit  "$name" "$instr" "$model" "$size" || exit 1 ;;
    esac
  done

  echo "Created team '$name' on:$resolved. Run /reload-plugins (claude) and re-scan agents (codex) as needed."
}

cmd_delete() {
  local name="${1:-}"
  [ -n "$name" ] || die "missing team name"
  [[ "$name" =~ $RESERVED_RE ]] && die "'$name' is reserved"
  local found=0
  if claude_has "$name"; then claude_remove "$name"; found=1; fi
  if codex_has  "$name"; then codex_remove  "$name"; found=1; fi
  [ $found -eq 1 ] || die "no such team: $name"
  echo "Deleted team '$name'."
}

cmd_delete_all() {
  local yes=0 dry=0 target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes)    yes=1; shift ;;
      --dry-run)   dry=1; shift ;;
      -t|--target) target="${2:-}"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local resolved
  resolved="$(targets_resolve "$target")" || exit 1

  local claude_names="" codex_names=""
  for t in $resolved; do
    case "$t" in
      claude) claude_names="$(claude_list_names | tr '\n' ' ')" ;;
      codex)  codex_names="$(codex_list_all_names | tr '\n' ' ')" ;;
    esac
  done

  echo "team delete-all plan (target:$resolved):"
  echo "  claude: ${claude_names:-<none>}"
  echo "  codex:  ${codex_names:-<none>}"

  if [ -z "${claude_names// }" ] && [ -z "${codex_names// }" ]; then
    echo "Nothing to delete."
    return 0
  fi

  if [ $dry -eq 1 ]; then
    echo "(dry-run) no changes made."
    return 0
  fi

  if [ $yes -ne 1 ]; then
    if [ ! -t 0 ]; then
      die "non-interactive: pass --yes to confirm"
    fi
    printf 'Delete ALL teams? [y/N] '
    local ans; read -r ans
    case "$ans" in
      y|Y|yes|YES) ;;
      *) echo "aborted."; return 1 ;;
    esac
  fi

  local n
  for t in $resolved; do
    case "$t" in
      claude)
        for n in $claude_names; do claude_remove "$n" || true; done
        ;;
      codex)
        for n in $codex_names; do codex_remove "$n" || true; done
        ;;
    esac
  done

  echo "Deleted all teams on:$resolved. Run /reload-plugins (claude) and re-scan agents (codex) as needed."
}

cmd_list() {
  shopt -s nullglob
  local orphans has_claude=0
  orphans="$(codex_list_orphans)"
  local f
  for f in "$CLAUDE_PLUGIN_ROOT/teams"/*.md; do
    has_claude=1
    break
  done
  if [ $has_claude -eq 0 ] && [ -z "$orphans" ]; then
    echo "No teams defined. Create one with /team:new --name <slug> --instructions \"...\""
    return
  fi
  printf '%-20s %-10s %-6s %-7s %-6s\n' "NAME" "MODEL" "SIZE" "CLAUDE" "CODEX"
  for f in "$CLAUDE_PLUGIN_ROOT/teams"/*.md; do
    local n m s c x
    n="$(basename "$f" .md)"
    m="$(awk '/^model:/{print $2; exit}' "$f")"
    s="$(awk '/^size:/{print $2; exit}'  "$f")"
    c="yes"
    if codex_has "$n"; then x="yes"; else x="-"; fi
    printf '%-20s %-10s %-6s %-7s %-6s\n' "$n" "${m:--}" "${s:--}" "$c" "$x"
  done
  for n in $orphans; do
    printf '%-20s %-10s %-6s %-7s %-6s\n' "$n" "-" "-" "-" "yes"
  done
}

cmd_seed() {
  local target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -t|--target) target="${2:-}"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local resolved
  resolved="$(targets_resolve "$target")" || exit 1

  . "$LIB/seed_data.sh"

  local created=0 skipped=0
  local entry name instr t any_missing
  for entry in "${INITIAL_TEAMS[@]}"; do
    name="${entry%%|*}"
    instr="${entry#*|}"
    [[ "$name" =~ $SLUG_RE ]] || die "seed has invalid slug: $name"
    [[ "$name" =~ $RESERVED_RE ]] && die "seed has reserved name: $name"

    any_missing=0
    for t in $resolved; do
      case "$t" in
        claude) claude_has "$name" || any_missing=1 ;;
        codex)  codex_has  "$name" || any_missing=1 ;;
      esac
    done

    if [ $any_missing -eq 0 ]; then
      echo "skip:    $name"
      skipped=$((skipped+1))
      continue
    fi

    for t in $resolved; do
      case "$t" in
        claude) claude_has "$name" || claude_emit "$name" "$instr" "" "" ;;
        codex)  codex_has  "$name" || codex_emit  "$name" "$instr" "" "" ;;
      esac
    done
    echo "created: $name"
    created=$((created+1))
  done

  echo "Seed done. created=$created skipped=$skipped target=$resolved"
  [ $created -gt 0 ] && echo "Run /reload-plugins (claude) and re-scan agents (codex) as needed."
  return 0
}

cmd_setup_claude() {
  local settings="${HOME}/.claude/settings.json"
  mkdir -p "$(dirname "$settings")"
  [ -f "$settings" ] || echo '{}' > "$settings"
  local tmp; tmp="$(mktemp)"
  jq '.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS = "1"' "$settings" > "$tmp"
  mv "$tmp" "$settings"
  echo "Set CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 in $settings"
  echo "Restart Claude Code for the env change to take effect."
}

cmd_uninstall() {
  local yes=0 dry=0 purge_codex=0 purge_env=0 keep=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes)              yes=1; shift ;;
      --dry-run)             dry=1; shift ;;
      --purge-codex-config)  purge_codex=1; shift ;;
      --purge-claude-env)    purge_env=1; shift ;;
      --keep-teams)          keep=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local claude_names codex_names
  claude_names="$(claude_list_names | tr '\n' ' ')"
  codex_names="$(codex_list_all_names | tr '\n' ' ')"
  local has_targets=0
  [ -f "$TARGETS_FILE" ] && has_targets=1

  echo "team-orchestrator uninstall plan:"
  if [ $keep -eq 1 ]; then
    echo "  teams (claude): keep"
    echo "  teams (codex):  keep"
  else
    echo "  teams (claude): ${claude_names:-<none>}"
    echo "  teams (codex):  ${codex_names:-<none>}"
  fi
  echo "  .targets.json:  $([ $has_targets -eq 1 ] && echo remove || echo absent)"
  [ $purge_codex -eq 1 ] && echo "  codex config:   purge [agents] block"
  [ $purge_env   -eq 1 ] && echo "  claude env:     remove CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"

  if [ $dry -eq 1 ]; then
    echo "(dry-run) no changes made."
    return 0
  fi

  if [ $yes -ne 1 ]; then
    if [ ! -t 0 ]; then
      die "non-interactive: pass --yes to confirm"
    fi
    printf 'Proceed? [y/N] '
    local ans; read -r ans
    case "$ans" in
      y|Y|yes|YES) ;;
      *) echo "aborted."; return 1 ;;
    esac
  fi

  if [ $keep -ne 1 ]; then
    claude_remove_all
    codex_remove_all
  fi
  targets_clear

  if [ $purge_codex -eq 1 ]; then
    codex_unsetup
  fi

  if [ $purge_env -eq 1 ]; then
    local settings="${HOME}/.claude/settings.json"
    if [ -f "$settings" ]; then
      local tmp; tmp="$(mktemp)"
      jq 'if .env then .env |= del(.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS) else . end' "$settings" > "$tmp"
      mv "$tmp" "$settings"
    fi
  fi

  echo "Uninstall complete. To remove the plugin binary itself, run: /plugin uninstall team"
}

cmd_setup_codex() {
  codex_setup
  targets_persist_codex
  echo "Codex target enabled. Subsequent /team:new will mirror to ~/.codex/agents/."
}

sub="${1:-}"
shift || true
case "$sub" in
  new)          cmd_new "$@" ;;
  delete)       cmd_delete "$@" ;;
  delete-all)   cmd_delete_all "$@" ;;
  list)         cmd_list "$@" ;;
  seed)         cmd_seed "$@" ;;
  setup-claude) cmd_setup_claude "$@" ;;
  setup-codex)  cmd_setup_codex  "$@" ;;
  uninstall)    cmd_uninstall    "$@" ;;
  ""|-h|--help|help)
    cat <<EOF
team — manage agent teams across Claude Code and Codex

Usage:
  team new (-n|--name) <slug> (-i|--instructions) "<text>" [(-m|--model) <m>] [(-s|--size) <n>] [(-t|--target) claude,codex]
  team delete <name>
  team delete-all [--yes] [--dry-run] [(-t|--target) claude,codex]
  team list
  team seed [(-t|--target) claude,codex]
  team setup-claude
  team setup-codex
  team uninstall [--yes] [--dry-run] [--keep-teams] [--purge-codex-config] [--purge-claude-env]
EOF
    ;;
  *) die "unknown subcommand: $sub" ;;
esac
